# Backend runtime settings
APP_ENV=dev
APP_TITLE=Object Detection & Tracking API
API_HOST=0.0.0.0
API_PORT=8000
MODEL_NAME=yolov8n.pt
PERFORMANCE_MODE=false
DEFAULT_PERFORMANCE_MODE=false
OCR_ENABLED=true
MAX_OBJECTS_PER_FRAME=50
UPLOAD_DIR=uploads
OUTPUT_DIR=storage/outputs
DATABASE_PATH=tracking.db
DB_URL=sqlite:///tracking.db
CORS_ORIGINS=*
LOG_LEVEL=INFO

# Frontend runtime settings
STREAMLIT_API_URL=http://127.0.0.1:8000
