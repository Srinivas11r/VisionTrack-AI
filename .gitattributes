# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Documentation
*.md text eol=lf
README* text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Batch files (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# JSON
*.json text eol=lf

# Binary files
*.pt binary
*.db binary
*.sqlite binary
*.mp4 binary
*.avi binary
*.mov binary
